# Buildbybim.space — Environment variables template
#
# Copy this file to `.env` (gitignored) and fill in your Supabase project values.
# `.env` is loaded by Vite at dev/build time. Only variables prefixed with VITE_
# are exposed to the browser bundle.
#
# Get these values from:
#   https://supabase.com/dashboard/project/<your-project>/settings/api

# Your Supabase project URL (e.g. https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key — safe to expose in browser
# (RLS policies enforce row-level security; never paste the service_role key here)
VITE_SUPABASE_ANON_KEY=

# Optional: enable Supabase sync features in the UI
# Leave unset or "false" to keep the app fully local-first (default).
VITE_SUPABASE_SYNC_ENABLED=false
